# ── 服务 ──────────────────────────────────────────
ZCODE_PORT=3000
ZCODE_HOST=0.0.0.0

# ── 数据目录（账号保存在本目录下的 SQLite）────────
ZCODE_DATA_DIR=./data

# ── 外部数据库（如果配了，账号池持久化进外部库）─────
# 留空 -> 仅用本地 SQLite兜底。
# PostgreSQL（Neon / Supabase 等免费托管）：
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# MySQL / MariaDB：
#   DATABASE_URL=mysql://user:pass@host:3306/dbname
# DATABASE_URL=

# ── 鉴权 ──────────────────────────────────────────
# 后台管理密码（首次启动写入 data/accounts.db，之后以数据库为准）
ZCODE_ADMIN_KEY=zcode

# ── 用量监控 ──────────────────────────────────────
# 后台自动刷新各账号额度的间隔（秒），0 关闭
ZCODE_QUOTA_REFRESH_INTERVAL=60
# 限流冷却时长（秒）
ZCODE_COOLING_SECONDS=300

# ── 无痕验证求解 ───────────────────────────────────
# 求解后端：jsdom（默认，Node 模拟浏览器，速度快但可能被设备指纹检测）
#         camoufox（真实浏览器指纹，通过率高，需安装: pip install camoufox && python -m camoufox fetch）
ZCODE_CAPTCHA_SOLVER=jsdom
# Node 可执行文件（默认走 PATH 中的 node）
# ZCODE_NODE_PATH=node
# 单次求解超时（秒）与失败重试次数
# ZCODE_CAPTCHA_TIMEOUT=40
# ZCODE_CAPTCHA_RETRIES=4
# camoufox 求解器选项（当 ZCODE_CAPTCHA_SOLVER=camoufox 时生效）
# 无头模式：1=无头（默认），0=有头（调试用）
# ZCODE_CAMOUFOX_HEADLESS=1
# camoufox 单次求解超时（秒）
# ZCODE_CAMOUFOX_TIMEOUT=60
# 阿里云验证请求的反向代理前缀（留空则直连阿里云）
# 例: REVERSE_URL=https://my-proxy.example.com/proxy/
# REVERSE_URL=

# ── 验证码缓存 ────────────────────────────────────
# CAPTCHA_CACHE_TTL=45000
# CAPTCHA_CONFIG_CACHE_TTL=600000

# ── 代理（验证码求解器使用，选填）────────────────
# PROXY_URL=http://127.0.0.1:7890

# ── 上游端点（一般无需修改）───────────────────────
# ZAI_UPSTREAM_URL=https://zcode.z.ai/api/v1/zcode-plan/anthropic/v1/messages
# ZAI_FALLBACK_URL=https://api.z.ai/api/anthropic/v1/messages
# BIGMODEL_UPSTREAM_URL=https://open.bigmodel.cn/api/anthropic/v1/messages
# UPSTREAM_USER_AGENT=ZCode/3.0.1
